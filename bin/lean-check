#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -ne 1 ]]; then
  echo "Usage: lean-check <file.lean>" >&2
  exit 1
fi
FILE="$1"

if [[ ! -e "$FILE" ]]; then
  echo "lean-check: file not found: $FILE" >&2
  exit 1
fi
if [[ ! -f "$FILE" ]]; then
  echo "lean-check: input is not a regular file: $FILE" >&2
  exit 1
fi
case "$FILE" in
  *.[Ll][Ee][Aa][Nn]) ;;
  *)
    echo "lean-check: input must be a .lean file: $FILE" >&2
    exit 1
    ;;
esac

ABS_DIR="$(cd -- "$(dirname -- "$FILE")" && pwd)"
ABS_FILE="${ABS_DIR%/}/$(basename -- "$FILE")"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
LOCAL_ELAN_HOME="$ROOT_DIR/.local/elan"
LOCAL_ELAN_BIN="$LOCAL_ELAN_HOME/bin"

resolve_command_path() {
  local cmd_path="$1"
  case "$cmd_path" in
    /*) printf '%s\n' "$cmd_path" ;;
    */*) printf '%s\n' "$(cd -- "$(dirname -- "$cmd_path")" && pwd)/$(basename -- "$cmd_path")" ;;
    *) printf '%s\n' "$cmd_path" ;;
  esac
}

is_executable_file() {
  [[ -f "$1" && -x "$1" ]]
}

local_elan_tool_path() {
  local tool="$1"
  if is_executable_file "$LOCAL_ELAN_BIN/$tool"; then
    printf '%s\n' "$LOCAL_ELAN_BIN/$tool"
    return 0
  fi
  if is_executable_file "$LOCAL_ELAN_BIN/$tool.exe"; then
    printf '%s\n' "$LOCAL_ELAN_BIN/$tool.exe"
    return 0
  fi
  return 1
}

if local_elan_tool_path lean >/dev/null && local_elan_tool_path lake >/dev/null; then
  export ELAN_HOME="$LOCAL_ELAN_HOME"
  export PATH="$LOCAL_ELAN_BIN:$PATH"
fi

MATHCODE=""
if [[ -x "$ROOT_DIR/mathcode" ]]; then
  MATHCODE="$ROOT_DIR/mathcode"
elif [[ -x "$SCRIPT_DIR/mathcode" ]]; then
  MATHCODE="$SCRIPT_DIR/mathcode"
fi

if [[ -n "$MATHCODE" ]]; then
  exec "$MATHCODE" --compile-check "$ABS_FILE"
fi

LEAN_PROJECT_DIR="${LEAN_PROJECT_DIR:-$ROOT_DIR/lean-workspace}"
if LAKE_CMD="$(command -v lake 2>/dev/null)" && [[ -d "$LEAN_PROJECT_DIR" ]]; then
  LAKE_CMD="$(resolve_command_path "$LAKE_CMD")"
  cd -- "$LEAN_PROJECT_DIR"
  exec "$LAKE_CMD" env lean "$ABS_FILE"
fi

if [[ -x "$ROOT_DIR/setup.sh" ]]; then
  echo "MathCode binary is not installed here yet. Run \`bash setup.sh\` first." >&2
else
  echo "lean-check: could not find the MathCode binary or a usable lake installation." >&2
fi
exit 1
